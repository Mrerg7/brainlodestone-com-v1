---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Footer from '../components/Footer.astro';
import Icon from '../components/Icon.astro';
import { getCollection } from 'astro:content';
import { CF_IMAGES } from '../lib/site';

const marketStats = (await getCollection('marketStats')).sort(
	(a, b) => a.data.order - b.data.order,
);
const useCases = (await getCollection('useCases')).sort(
	(a, b) => a.data.order - b.data.order,
);
const valuePillars = (await getCollection('valuePillars')).sort(
	(a, b) => a.data.order - b.data.order,
);

const iconMap = {
	magnet: 'magnet',
	search: 'search',
	globe: 'globe',
	handshake: 'handshake',
	shield: 'shield',
	rocket: 'rocket',
} as const;
---

<BaseLayout>
	<Nav />
	<main>
		<Hero />

		<!-- TRUST / MARKET STATS BAR -->
		<div class="border-b border-slate-800 bg-slate-900/60">
			<div class="max-w-screen-2xl mx-auto px-6 md:px-12 lg:px-16 py-6">
				<div class="grid grid-cols-2 md:grid-cols-4 gap-y-6 gap-x-4 text-center md:text-left">
					{
						marketStats.map((stat) => (
							<div>
								<div class="font-mono text-3xl font-semibold text-teal-400 stat-number">{stat.data.value}</div>
								<div class="text-xs uppercase tracking-widest text-slate-400 mt-1">{stat.data.label}</div>
							</div>
						))
					}
				</div>
			</div>
		</div>

		<!-- THE OPPORTUNITY -->
		<section id="opportunity" class="max-w-screen-2xl mx-auto px-6 md:px-12 lg:px-16 pt-20 pb-16">
			<div class="max-w-3xl mb-12">
				<div class="uppercase text-teal-400 text-xs font-semibold tracking-[2px] mb-3">THE MARKET MOMENT</div>
				<h2 class="text-4xl md:text-5xl font-bold tracking-tighter">A once-in-a-generation opportunity in brain health.</h2>
				<p class="mt-5 text-xl text-slate-300">Major depressive disorder affects over 21 million U.S. adults annually. For the significant portion who do not respond to medication or therapy, TMS offers new hope — and explosive demand for trusted brands.</p>
			</div>

			<div class="grid md:grid-cols-3 gap-6">
				<div class="glass rounded-3xl p-8 benefit-card">
					<div class="w-11 h-11 rounded-2xl bg-teal-400/10 flex items-center justify-center mb-6">
						<Icon name="chart-line" class="w-7 h-7 text-teal-400" />
					</div>
					<h3 class="font-semibold text-xl tracking-tight mb-3">Explosive Category Growth</h3>
					<p class="text-slate-300 text-[15px]">The TMS systems and services market is projected to reach $2–4 billion by the early 2030s. Clinics, device manufacturers, and digital platforms are scaling rapidly across North America and globally.</p>
				</div>

				<div class="glass rounded-3xl p-8 benefit-card">
					<div class="w-11 h-11 rounded-2xl bg-teal-400/10 flex items-center justify-center mb-6">
						<Icon name="shield" class="w-7 h-7 text-teal-400" />
					</div>
					<h3 class="font-semibold text-xl tracking-tight mb-3">Proven Clinical Outcomes</h3>
					<p class="text-slate-300 text-[15px]">FDA-cleared for major depression, OCD, migraines, and smoking cessation. Real-world response rates of 50–65% and remission rates of 30–40% in patients who failed multiple prior treatments.</p>
				</div>

				<div class="glass rounded-3xl p-8 benefit-card">
					<div class="w-11 h-11 rounded-2xl bg-teal-400/10 flex items-center justify-center mb-6">
						<Icon name="globe" class="w-7 h-7 text-teal-400" />
					</div>
					<h3 class="font-semibold text-xl tracking-tight mb-3">Brand-Ready Territory</h3>
					<p class="text-slate-300 text-[15px]">Most TMS providers still operate under generic or clinical names. brainlodestone.com delivers instant differentiation, memorability, and SEO alignment in a high-intent category.</p>
				</div>
			</div>
		</section>

		<!-- THE SCIENCE -->
		<section id="science" class="bg-slate-900 border-y border-slate-800">
			<div class="max-w-screen-2xl mx-auto px-6 md:px-12 lg:px-16 py-20">
				<div class="grid lg:grid-cols-12 gap-x-12 gap-y-10 items-center">
					<div class="lg:col-span-7">
						<div class="uppercase text-teal-400 text-xs font-semibold tracking-[2px] mb-3">GROUNDED IN CLINICAL EVIDENCE</div>
						<h2 class="text-4xl md:text-5xl font-bold tracking-tighter mb-6">Non-invasive. Precise. Life-changing.</h2>

						<div class="space-y-6 text-[15.2px] text-slate-300">
							<p>Transcranial magnetic stimulation (TMS) uses targeted magnetic fields to stimulate nerve cells in brain regions involved in mood regulation. It is FDA-approved and typically recommended when standard treatments such as medication and psychotherapy have not been effective.</p>

							<div class="grid sm:grid-cols-2 gap-4 pt-2">
								<div class="flex gap-3">
									<Icon name="check" class="w-5 h-5 text-teal-400 shrink-0 mt-0.5" />
									<div><span class="font-medium text-white">No surgery. No anesthesia.</span><br /><span class="text-sm">Outpatient procedure performed in a clinic.</span></div>
								</div>
								<div class="flex gap-3">
									<Icon name="check" class="w-5 h-5 text-teal-400 shrink-0 mt-0.5" />
									<div><span class="font-medium text-white">Minimal side effects.</span><br /><span class="text-sm">Most common: mild scalp discomfort or headache that improves quickly.</span></div>
								</div>
								<div class="flex gap-3">
									<Icon name="check" class="w-5 h-5 text-teal-400 shrink-0 mt-0.5" />
									<div><span class="font-medium text-white">FDA-cleared indications.</span><br /><span class="text-sm">Major depression, OCD, migraines, and smoking cessation.</span></div>
								</div>
								<div class="flex gap-3">
									<Icon name="check" class="w-5 h-5 text-teal-400 shrink-0 mt-0.5" />
									<div><span class="font-medium text-white">Growing research pipeline.</span><br /><span class="text-sm">Ongoing studies for epilepsy, anxiety, PTSD, and more.</span></div>
								</div>
							</div>
						</div>

						<a href="#contact" class="mt-8 inline-flex items-center text-sm text-teal-400 hover:text-teal-300 transition-colors">
							<span class="font-medium">Own the brand that patients and referrers will remember</span>
							<Icon name="arrow-right" class="w-4 h-4 ml-2" />
						</a>
					</div>

					<div class="lg:col-span-5 relative">
						<div class="rounded-3xl overflow-hidden border border-slate-700 shadow-2xl">
							<img
								src={CF_IMAGES.science}
								alt="Patient receiving TMS therapy in a modern clinical setting"
								class="w-full h-auto object-cover"
								width={800}
								height={600}
								loading="lazy"
							/>
						</div>
						<div class="absolute -bottom-4 -left-4 bg-slate-900 border border-slate-700 rounded-2xl px-5 py-3 text-xs shadow-xl max-w-[210px]">
							<div class="font-medium text-white">"TMS is one of the fastest growing treatment techniques in mental health."</div>
							<div class="text-teal-400 text-[10px] mt-1">— Clinical TMS Society & leading providers</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- WHY THIS DOMAIN -->
		<section id="why" class="max-w-screen-2xl mx-auto px-6 md:px-12 lg:px-16 py-20">
			<div class="max-w-2xl mb-12">
				<div class="text-teal-400 text-xs font-semibold tracking-[2px]">THE STRATEGIC ADVANTAGE</div>
				<h2 class="text-4xl md:text-5xl font-bold tracking-tighter mt-2">Why brainlodestone.com is a lodestone for success.</h2>
				<p class="mt-4 text-lg text-slate-300">"Lodestone" is not just poetic — it literally describes a naturally magnetic stone. In a category defined by magnetic pulses and attracting better patient outcomes, this name is powerfully on-brand.</p>
			</div>

			<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
				{
					valuePillars.map((pillar) => (
						<div class="benefit-card border border-slate-800 rounded-3xl p-8 hover:border-teal-900/60 transition-colors">
							<div class="flex items-center gap-x-3 mb-5">
								<div class="text-teal-400">
									<Icon name={iconMap[pillar.data.icon]} class="w-8 h-8" />
								</div>
								<div class="font-semibold text-xl tracking-tight">{pillar.data.title}</div>
							</div>
							<p class="text-slate-300">{pillar.data.description}</p>
						</div>
					))
				}
			</div>
		</section>

		<!-- PERFECT FOR / USE CASES -->
		<section id="perfect-for" class="max-w-screen-2xl mx-auto px-6 md:px-12 lg:px-16 pb-20">
			<div class="text-center mb-12">
				<div class="text-teal-400 text-xs font-semibold tracking-[2px]">IDEAL BRAND FIT</div>
				<h2 class="text-4xl md:text-5xl font-bold tracking-tighter mt-2">Built for category leaders.</h2>
			</div>

			<div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
				{
					useCases.map((item) => (
						<div class="group rounded-3xl border border-slate-800 p-7 hover:border-teal-900/50 transition-all">
							<div class="mb-4 text-teal-400">
								<Icon name={iconMap[item.data.icon]} class="w-8 h-8" />
							</div>
							<div class="font-semibold text-lg mb-1.5">{item.data.title}</div>
							<p class="text-sm text-slate-400">{item.data.description}</p>
						</div>
					))
				}
			</div>

			<div class="mt-8 text-center">
				<p class="text-sm text-slate-400 max-w-md mx-auto">The name works across B2B and B2C — from institutional partnerships to direct-to-patient marketing.</p>
			</div>
		</section>

		<!-- BRAND VISUAL -->
		<section class="border-y border-slate-800 bg-slate-900 py-16">
			<div class="max-w-screen-2xl mx-auto px-6 md:px-12 lg:px-16">
				<div class="grid lg:grid-cols-12 gap-x-12 items-center">
					<div class="lg:col-span-5 mb-10 lg:mb-0">
						<div class="uppercase text-xs tracking-[2px] text-teal-400 font-semibold mb-3">INSTANT BRAND EQUITY</div>
						<h3 class="text-4xl font-display tracking-tighter font-semibold leading-none">See the brand<br />come to life.</h3>
						<p class="mt-5 text-slate-300">brainlodestone.com delivers a complete, ownable visual and verbal identity from day one. Clean, modern, and unmistakably relevant.</p>

						<div class="mt-8 flex flex-wrap gap-3">
							<div class="px-4 py-1.5 rounded-full bg-slate-800 text-xs font-medium flex items-center gap-x-2">
								<Icon name="check" class="w-4 h-4 text-teal-400" />
								<span>Premium logo suite included</span>
							</div>
							<div class="px-4 py-1.5 rounded-full bg-slate-800 text-xs font-medium flex items-center gap-x-2">
								<Icon name="check" class="w-4 h-4 text-teal-400" />
								<span>Color system & guidelines</span>
							</div>
						</div>
					</div>

					<div class="lg:col-span-7">
						<div class="rounded-3xl overflow-hidden border border-slate-700 bg-white p-10 flex items-center justify-center">
							<img
								src={CF_IMAGES.brand}
								alt="Brain Lodestone premium logo concept"
								width={600}
								height={200}
								class="max-h-[170px] w-auto"
								loading="lazy"
							/>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- ACQUIRE / LEAD FORM -->
		<section id="acquire" class="max-w-screen-2xl mx-auto px-6 md:px-12 lg:px-16 py-20">
			<div class="max-w-2xl mx-auto text-center mb-10">
				<div class="inline-block px-4 py-1 rounded-full bg-teal-400/10 text-teal-400 text-xs font-semibold tracking-widest mb-4">SECURE YOUR POSITION</div>
				<h2 class="text-4xl md:text-5xl font-bold tracking-tighter">Ready to own brainlodestone.com?</h2>
				<p class="mt-4 text-lg text-slate-300">This premium domain is available for acquisition. Inquire today for pricing, flexible payment options, and a seamless escrow-protected transfer.</p>
			</div>

			<div class="max-w-[620px] mx-auto">
				<div class="glass rounded-3xl p-8 md:p-10 border border-slate-700">
					<form id="inquiry-form" class="space-y-5">
						<div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
							<div>
								<label class="block text-xs font-medium tracking-wider text-slate-400 mb-1.5" for="full-name">FULL NAME</label>
								<input type="text" id="full-name" required
									class="w-full bg-slate-900 border border-slate-700 focus:border-teal-500 rounded-2xl px-5 py-3.5 text-sm placeholder:text-slate-500 outline-none transition-colors text-white" />
							</div>
							<div>
								<label class="block text-xs font-medium tracking-wider text-slate-400 mb-1.5" for="email">EMAIL ADDRESS</label>
								<input type="email" id="email" required
									class="w-full bg-slate-900 border border-slate-700 focus:border-teal-500 rounded-2xl px-5 py-3.5 text-sm placeholder:text-slate-500 outline-none transition-colors text-white" />
							</div>
						</div>

						<div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
							<div>
								<label class="block text-xs font-medium tracking-wider text-slate-400 mb-1.5" for="phone">PHONE (OPTIONAL)</label>
								<input type="tel" id="phone"
									class="w-full bg-slate-900 border border-slate-700 focus:border-teal-500 rounded-2xl px-5 py-3.5 text-sm placeholder:text-slate-500 outline-none transition-colors text-white" />
							</div>
							<div>
								<label class="block text-xs font-medium tracking-wider text-slate-400 mb-1.5" for="intended-use">INTENDED USE</label>
								<select id="intended-use" required
									class="w-full bg-slate-900 border border-slate-700 focus:border-teal-500 rounded-2xl px-5 py-3.5 text-sm text-white outline-none transition-colors">
									<option value="">Select category...</option>
									<option value="TMS / Mental Health Clinic">TMS / Mental Health Clinic Network</option>
									<option value="Neurotechnology / Device Company">Neurotechnology or Medical Device Company</option>
									<option value="Digital Health Platform">Digital Health or Telehealth Platform</option>
									<option value="Research / Academic / Nonprofit">Research, Academic, or Nonprofit</option>
									<option value="Investment / Domain Portfolio">Investment or Domain Portfolio</option>
									<option value="Other">Other / Not Disclosed</option>
								</select>
							</div>
						</div>

						<div>
							<label class="block text-xs font-medium tracking-wider text-slate-400 mb-1.5" for="message">MESSAGE OR QUESTIONS</label>
							<textarea id="message" rows="3" placeholder="Tell us about your vision for brainlodestone.com..."
								class="w-full resize-y bg-slate-900 border border-slate-700 focus:border-teal-500 rounded-3xl px-5 py-4 text-sm placeholder:text-slate-500 outline-none transition-colors text-white"></textarea>
						</div>

						<button type="submit"
							class="w-full mt-2 flex items-center justify-center gap-x-3 bg-white hover:bg-slate-100 active:bg-slate-200 transition-all text-slate-900 font-semibold text-base py-4 rounded-3xl shadow-inner">
							<span>Submit Inquiry</span>
							<Icon name="mail" class="w-5 h-5" />
						</button>

						<p class="text-center text-[10px] text-slate-500 pt-1">Your information is kept strictly confidential. We respond within 24 hours.</p>
					</form>

					<!-- Success State -->
					<div id="form-success" class="hidden text-center py-8">
						<div class="mx-auto w-16 h-16 rounded-full bg-teal-400/10 flex items-center justify-center mb-6">
							<Icon name="check" class="w-10 h-10 text-teal-400" />
						</div>
						<h4 class="font-semibold text-2xl tracking-tight">Thank you. Your inquiry has been received.</h4>
						<p class="mt-3 text-slate-300 max-w-xs mx-auto">A member of our acquisitions team will contact you within 24 hours to discuss next steps, pricing, and secure transfer options.</p>
						<button onclick="resetForm()"
							class="mt-8 text-sm font-medium text-teal-400 hover:text-teal-300 underline underline-offset-4">Submit another inquiry</button>
					</div>
				</div>

				<div class="text-center mt-6 text-xs text-slate-500 flex items-center justify-center gap-x-2">
					<Icon name="lock" class="w-4 h-4" />
					<span>Secure escrow via Escrow.com or preferred provider • Full transparency • Flexible terms available</span>
				</div>
			</div>
		</section>

		<!-- FINAL CTA / FOOTER TEASER -->
		<div class="border-t border-slate-800 bg-slate-900 py-9">
			<div class="max-w-screen-2xl mx-auto px-6 md:px-12 lg:px-16 text-center">
				<p class="text-sm text-slate-400">The mental health innovation economy is being built right now.<br class="hidden sm:block" /> <span class="text-white font-medium">brainlodestone.com</span> is the address for those leading it.</p>
			</div>
		</div>
	</main>
	<Footer />
</BaseLayout>

<script>
	function initForm() {
		const form = document.getElementById('inquiry-form') as HTMLFormElement | null;
		const successState = document.getElementById('form-success') as HTMLElement | null;

		if (!form) return;

		form.addEventListener('submit', function (e: SubmitEvent) {
			e.preventDefault();
			const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;
			if (!submitBtn) return;

			submitBtn.disabled = true;
			submitBtn.innerHTML = `<span class="flex items-center justify-center gap-x-2"><svg class="animate-spin w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg><span>Processing...</span></span>`;

			setTimeout(() => {
				form.classList.add('hidden');
				if (successState) successState.classList.remove('hidden');
			}, 850);
		});
	}

	(window as any).resetForm = function () {
		const form = document.getElementById('inquiry-form') as HTMLFormElement | null;
		const successState = document.getElementById('form-success') as HTMLElement | null;
		if (!form || !successState) return;
		successState.classList.add('hidden');
		form.classList.remove('hidden');
		form.reset();
		const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;
		if (!submitBtn) return;
		submitBtn.disabled = false;
		submitBtn.innerHTML = '<span>Submit Inquiry</span><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><path d="M4 6h16v12H4V6zm0 0l8 7 8-7"/></svg>';
	};

	function initSmoothScroll() {
		document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
			anchor.addEventListener('click', function (this: HTMLAnchorElement, e: Event) {
				const href = this.getAttribute('href');
				if (!href) return;
				const targetId = href.substring(1);
				const targetElement = document.getElementById(targetId);
				if (targetElement) {
					e.preventDefault();
					const navHeight = 80;
					const elementPosition = targetElement.getBoundingClientRect().top;
					const offsetPosition = elementPosition + window.scrollY - navHeight;
					window.scrollTo({ top: offsetPosition, behavior: 'smooth' });
				}
			});
		});
	}

	initForm();
	initSmoothScroll();
</script>
