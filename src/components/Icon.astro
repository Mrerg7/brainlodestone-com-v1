---
type IconName =
	| 'arrow-right'
	| 'chevron-down'
	| 'magnet'
	| 'chart-line'
	| 'shield'
	| 'globe'
	| 'search'
	| 'handshake'
	| 'rocket'
	| 'hospital'
	| 'microchip'
	| 'laptop-medical'
	| 'flask'
	| 'check'
	| 'lock'
	| 'mail';

interface Props {
	name: IconName;
	class?: string;
}

const { name, class: className = 'w-5 h-5' } = Astro.props;

const paths: Record<IconName, string> = {
	'arrow-right': 'M5 12h14M13 6l6 6-6 6',
	'chevron-down': 'M6 9l6 6 6-6',
	magnet: 'M4 3h6v10a2 2 0 004 0V3h6v10a8 8 0 01-16 0V3z M4 13h16',
	'chart-line': 'M3 3v18h18 M7 16l4-4 4 4 5-5',
	shield: 'M12 2l7 4v6c0 5-3.5 9.5-7 10-3.5-.5-7-5-7-10V6l7-4z',
	globe: 'M12 2a10 10 0 100 20 10 10 0 000-20zM2 12h20M12 2c2.5 3 4 6.5 4 10s-1.5 7-4 10M12 2c-2.5 3-4 6.5-4 10s1.5 7 4 10',
	search: 'M11 19a8 8 0 100-16 8 8 0 000 16zM21 21l-4.35-4.35',
	handshake: 'M5.5 12.5L8 10l3 3 5-5-2.5-2.5L11 8l-1-1-3.5 3.5L5.5 12.5z M4.5 14.5l4 4M19.5 5.5l-4-4',
	rocket: 'M4.5 16.5c6-6 11-11 15-13 2 4-7 9-13 15-2-2-2-2z M9 15l-3 3',
	hospital: 'M3 3h18v18H3V3z M7 7h4v4H7V7z M13 7h4v4h-4V7z M7 13h4v4H7v-4z M13 13h4v4h-4v-4z M5 21h14',
	microchip: 'M6 3h12v6h-3v3h3v6H6v-6h3v-3H6V3z M9 15h6 M9 9h6',
	'laptop-medical': 'M3 7a2 2 0 012-2h14a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V7z M8 10h8v4H8v-4z M2 18h20',
	flask: 'M9 3h6 M10 3v7l5 10H9L4 10V3 M8 13h8',
	check: 'M5 12l4 4L19 6',
	lock: 'M7 11V8a5 5 0 0110 0v3M6 11h12v10H6V11z M12 15v2',
	mail: 'M4 6h16v12H4V6zm0 0l8 7 8-7',
};

const strokeIcons: IconName[] = [
	'arrow-right', 'chevron-down', 'magnet', 'chart-line', 'shield',
	'globe', 'search', 'handshake', 'rocket', 'hospital', 'microchip',
	'laptop-medical', 'flask', 'check', 'lock', 'mail',
];
const isStroke = strokeIcons.includes(name);
---

<svg
	xmlns="http://www.w3.org/2000/svg"
	viewBox="0 0 24 24"
	class={className}
	fill={isStroke ? 'none' : 'currentColor'}
	stroke={isStroke ? 'currentColor' : 'none'}
	stroke-width={isStroke ? '2' : undefined}
	stroke-linecap="round"
	stroke-linejoin="round"
	aria-hidden="true"
>
	<path d={paths[name]} />
</svg>
