---
import AcquisitionCta from './AcquisitionCta.astro';
import Icon from './Icon.astro';
import { CF_IMAGES, SITE } from '../lib/site';
---

<section
	class="hero-bg min-h-[100dvh] flex items-center relative pt-16 md:pt-0"
	style={`background-image: linear-gradient(rgba(15, 23, 42, 0.65), rgba(15, 23, 42, 0.75)), url('${CF_IMAGES.hero}');`}
>
	<div class="max-w-screen-2xl mx-auto px-6 md:px-12 lg:px-16 py-16 md:py-20 w-full">
		<div class="max-w-3xl">
			<!-- Trust badge -->
			<div class="inline-flex items-center gap-x-2 rounded-3xl bg-white/10 backdrop-blur-md border border-white/20 px-4 py-1.5 mb-8">
				<div class="flex -space-x-1">
					<div class="w-5 h-5 bg-teal-400 rounded-full ring-2 ring-slate-950"></div>
					<div class="w-5 h-5 bg-cyan-400 rounded-full ring-2 ring-slate-950"></div>
				</div>
				<span class="text-xs font-medium tracking-[0.5px] text-white/90">PREMIUM • EXACT-MATCH • HIGH-INTENT</span>
			</div>

			<h1 class="text-6xl md:text-7xl lg:text-7xl font-display font-semibold tracking-tighter leading-[0.96] mb-6">
				brainlodestone.com
			</h1>

			<p class="max-w-lg text-2xl md:text-3xl font-medium tracking-tight text-white mb-4">
				{SITE.tagline}
			</p>

			<p class="max-w-md text-lg text-slate-300 mb-10">
				A rare, brandable .com perfectly aligned with Transcranial Magnetic Stimulation (TMS),
				neurotechnology, and the rapidly expanding mental health innovation economy.
			</p>

			<div class="flex flex-col sm:flex-row gap-4">
				<AcquisitionCta
					label="Acquire This Domain"
					variant="gradient"
					size="lg"
				/>
				<a
					href="#why"
					class="inline-flex items-center justify-center gap-x-2 px-7 py-4 text-lg font-medium rounded-full border border-white/30 hover:bg-white/5 active:bg-white/10 transition-all"
				>
					Why it converts
				</a>
			</div>

			<div class="mt-8 flex items-center gap-x-6 text-sm">
				<div class="flex items-center gap-x-2 text-teal-400">
					<Icon name="check" class="w-5 h-5" />
					<span class="font-medium">Instant brand authority</span>
				</div>
				<div class="hidden sm:block w-px h-3.5 bg-white/30"></div>
				<div class="text-slate-400 text-sm">Escrow-protected acquisition</div>
			</div>
		</div>
	</div>

	<!-- Scroll indicator -->
	<div class="absolute bottom-10 left-1/2 hidden lg:flex flex-col items-center gap-y-1 text-xs tracking-[1.5px] text-white/50 -translate-x-1/2">
		<div>SCROLL TO EXPLORE</div>
		<Icon name="chevron-down" class="w-5 h-5 animate-bounce" />
	</div>
</section>
